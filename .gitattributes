# Default: treat as text and normalize to LF in repo
* text=auto eol=lf

# Windows batch files should be CRLF
*.bat text eol=crlf
*.cmd text eol=crlf

# Explicitly mark common binaries (no EOL normalization, no diffs)
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.webp binary
*.ico binary
*.pdf binary
*.zip binary
*.gz binary
*.7z binary
*.jar binary
*.exe binary
*.dll binary
*.woff binary
*.woff2 binary
*.ttf binary
*.eot binary
*.mp4 binary
*.mov binary
*.mp3 binary
*.wav binary

# Common text formats (explicit, belt & suspenders)
*.sol text eol=lf
*.ts  text eol=lf
*.tsx text eol=lf
*.js  text eol=lf
*.mjs text eol=lf
*.cjs text eol=lf
*.json text eol=lf
*.md  text eol=lf
*.yml text eol=lf
*.yaml text eol=lf
*.toml text eol=lf
*.sh  text eol=lf
*.env text eol=lf