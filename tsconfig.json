{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2022"],
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "strict": true,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "forceConsistentCasingInFileNames": true,
    "skipLibCheck": true,
    "allowImportingTsExtensions": true,
    "types": ["node", "mocha"],
    "noEmit": true
  },
  "include": [
    "hardhat.config.ts",
    "contracts/**/*.ts",
    "por/**/*.ts",
    "tools/**/*.ts"
  ],
  "exclude": [
    "node_modules",
    "contracts/artifacts",
    "contracts/cache"
  ]
}